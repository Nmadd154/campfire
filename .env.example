# Appwrite Configuration
# Copy this file to .env and fill in your Appwrite project details

# OPTION 1: Use Demo Mode (no backend setup required)
# Leave these blank or set EXPO_PUBLIC_FORCE_DEMO_MODE=true to use mock data
EXPO_PUBLIC_FORCE_DEMO_MODE=true

# OPTION 2: Use Appwrite Backend
# Fill in these values to connect to your Appwrite instance
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://sfo.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=
EXPO_PUBLIC_APPWRITE_DATABASE_ID=

# Instructions for Appwrite Setup:
# 1. Create a free Appwrite account at https://cloud.appwrite.io
# 2. Create a new project
# 3. Copy your Project ID from the Appwrite dashboard
# 4. Create a new database and copy the Database ID
# 5. Replace the values above with your own
# 6. Set EXPO_PUBLIC_FORCE_DEMO_MODE=false or remove that line
